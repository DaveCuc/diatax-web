# =========================================================================
# diatax-web Environment Variables (ADK 2.0 Credentials Configuration)
# =========================================================================

# --- OPTION A: Google AI Studio (Gemini Developer API) ---
# Use this option if you want to connect via API Key from AI Studio.
# GEMINI_API_KEY=your_google_ai_studio_api_key_here

# --- OPTION B: Google Cloud Platform (Vertex AI API) ---
# Use this option for enterprise-grade deployment and Vertex AI integration.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id-here
GOOGLE_CLOUD_LOCATION=global

# --- App Settings ---
PORT=8000
HOST=0.0.0.0
ALLOW_ORIGINS=*

# --- Gemini Model Configuration ---
# You can change the model version here (e.g. gemini-2.5-flash, gemini-2.5-pro, etc.)
GEMINI_MODEL=gemini-2.5-flash
